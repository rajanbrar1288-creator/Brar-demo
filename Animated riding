  <script>
    /* ════════════════════════════════════════
       1. SPEED LINES — Hero Background
       ════════════════════════════════════════ */
    const speedContainer = document.getElementById('speedLines');
    function createSpeedLine() {
      const line = document.createElement('div');
      line.classList.add('speed-line');
      const top = Math.random() * 100;
      const width = 80 + Math.random() * 200;
      const duration = 2 + Math.random() * 3;
      const delay = Math.random() * 5;
      line.style.cssText = `top:${top}%;width:${width}px;animation-duration:${duration}s;animation-delay:${delay}s;`;
      speedContainer.appendChild(line);
      setTimeout(() => line.remove(), (duration + delay) * 1000);
    }
    // Initial burst
    for (let i = 0; i < 12; i++) createSpeedLine();
    // Continuous generation
    setInterval(createSpeedLine, 600);

    /* ════════════════════════════════════════
       2. PARTICLE CANVAS — Ambient Sparks
       ════════════════════════════════════════ */
    const canvas = document.getElementById('particleCanvas');
    const ctx = canvas.getContext('2d');
    let particles = [];
    let mouse = { x: -1000, y: -1000 };

    function resizeCanvas() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    document.addEventListener('mousemove', e => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
    });

    class Particle {
      constructor(x, y, burst = false) {
        this.x = x || Math.random() * canvas.width;
        this.y = y || Math.random() * canvas.height;
        this.size = burst ? (1 + Math.random() * 3) : (0.5 + Math.random() * 1.5);
        this.speedX = burst ? (Math.random() - 0.5) * 4 : (Math.random() - 0.5) * 0.3;
        this.speedY = burst ? (-Math.random() * 5 - 1) : (-Math.random() * 0.5 - 0.1);
        this.life = 1;
        this.decay = burst ? (0.01 + Math.random() * 0.03) : (0.001 + Math.random() * 0.003);
        this.color = burst
          ? `rgba(245, ${Math.floor(130 + Math.random() * 100)}, ${Math.floor(Math.random() * 50)}, `
          : `rgba(245, 158, 11, `;
      }
      update() {
        this.x += this.speedX;
        this.y += this.speedY;
        this.life -= this.decay;
        // Mouse attraction (subtle)
        const dx = mouse.x - this.x;
        const dy = mouse.y - this.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 200 && dist > 0) {
          this.speedX += (dx / dist) * 0.02;
          this.speedY += (dy / dist) * 0.02;
        }
      }
      draw() {
        if (this.life <= 0) return;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fillStyle = this.color + (this.life * 0.6) + ')';
        ctx.fill();
        // Glow
        if (this.size > 1.5) {
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.size * 3, 0, Math.PI * 2);
          ctx.fillStyle = this.color + (this.life * 0.1) + ')';
          ctx.fill();
        }
      }
    }

    // Ambient particles
    for (let i = 0; i < 40; i++) particles.push(new Particle());

    function burstParticles(x, y, count = 20) {
      for (let i = 0; i < count; i++) particles.push(new Particle(x, y, true));
    }

    function animateParticles() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles = particles.filter(p => p.life > 0);
      particles.forEach(p => { p.update(); p.draw(); });
      // Keep ambient count up
      if (particles.length < 40) particles.push(new Particle());
      requestAnimationFrame(animateParticles);
    }
    animateParticles();

    /* ════════════════════════════════════════
       3. SCROLL REVEAL — Intersection Observer
       ════════════════════════════════════════ */
    const revealEls = document.querySelectorAll('.reveal, .reveal-scale, .reveal-left, .reveal-right');
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    revealEls.forEach(el => revealObserver.observe(el));

    /* ════════════════════════════════════════
       4. COUNTER ANIMATION — Stats Numbers
       ════════════════════════════════════════ */
    const statNumbers = document.querySelectorAll('.stat-number');
    let countersDone = false;

    function animateCounters() {
      if (countersDone) return;
      countersDone = true;
      statNumbers.forEach(el => {
        const target = parseInt(el.dataset.target);
        const suffix = el.dataset.suffix || '';
        const duration = 2000;
        const startTime = performance.now();

        function updateCounter(currentTime) {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          // Ease out cubic
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.floor(eased * target);
          el.textContent = current.toLocaleString() + suffix;
          if (progress < 1) requestAnimationFrame(updateCounter);
        }
        requestAnimationFrame(updateCounter);
      });
    }

    const statsSection = document.getElementById('stats');
    const statsObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) animateCounters();
      });
    }, { threshold: 0.3 });
    statsObserver.observe(statsSection);

    /* ════════════════════════════════════════
       5. PROGRESS RINGS — SVG Animation
       ════════════════════════════════════════ */
    const progressRings = document.querySelectorAll('.progress-ring-circle');
    let ringsDone = false;

    function animateRings() {
      if (ringsDone) return;
      ringsDone = true;
      progressRings.forEach(ring => {
        const targetOffset = parseInt(ring.dataset.targetOffset);
        setTimeout(() => {
          ring.style.strokeDashoffset = targetOffset;
        }, 300);
      });
    }

    const mantraSection = document.getElementById('mantra');
    const ringsObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) animateRings();
      });
    }, { threshold: 0.4 });
    ringsObserver.observe(mantraSection);

    /* ════════════════════════════════════════
       6. TOAST SYSTEM
       ════════════════════════════════════════ */
    const toast = document.getElementById('toast');
    const toastMsg = document.getElementById('toastMsg');
    let toastTimer = null;

    function showToast(msg, duration = 3000) {
      clearTimeout(toastTimer);
      toastMsg.textContent = msg;
      toast.style.opacity = '1';
      toast.style.transform = 'translate(-50%, 0)';
      toast.style.pointerEvents = 'auto';
      toastTimer = setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translate(-50%, -16px)';
        toast.style.pointerEvents = 'none';
      }, duration);
    }

    /* ════════════════════════════════════════
       7. FULLSCREEN RIDE OVERLAY
       ════════════════════════════════════════ */
    const overlay = document.getElementById('rideOverlay');
    const overlayTitle = document.getElementById('overlayTitle');
    const overlaySub = document.getElementById('overlaySub');

    const rideSequence = [
      { title: 'RIDE', sub: 'The road is calling...', delay: 1200 },
      { title: 'PUSH', sub: 'Your legs can take more...', delay: 1000 },
      { title: 'SUFFER', sub: 'Embrace the pain...', delay: 1000 },
      { title: 'RISE', sub: 'You are unstoppable.', delay: 1200 },
    ];

    function triggerRideSequence() {
      overlay.classList.add('show');
      let idx = 0;

      function showNext() {
        if (idx >= rideSequence.length) {
          // Final burst + close
          burstParticles(canvas.width / 2, canvas.height / 2, 80);
          setTimeout(() => {
            overlay.classList.remove('show');
            showToast('Now go ride. No excuses. 🔥', 4000);
          }, 600);
          return;
        }

        const step = rideSequence[idx];
        const content = document.getElementById('overlayContent');
        content.style.opacity = '0';
        content.style.transform = 'translateY(20px)';

        setTimeout(() => {
          overlayTitle.textContent = step.title;
          overlaySub.textContent = step.sub;
          content.style.opacity = '1';
          content.style.transform = 'translateY(0)';
          burstParticles(canvas.width / 2, canvas.height / 2, 15);
          idx++;
          setTimeout(showNext, step.delay);
        }, 400);
      }

      setTimeout(showNext, 500);
    }

    /* ════════════════════════════════════════
       8. BUTTON EVENT LISTENERS
       ════════════════════════════════════════ */
    document.getElementById('heroRideBtn').addEventListener('click', (e) => {
      burstParticles(e.clientX, e.clientY, 30);
      triggerRideSequence();
    });

    document.getElementById('startBtn').addEventListener('click', (e) => {
      burstParticles(e.clientX, e.clientY, 25);
      triggerRideSequence();
    });

    document.getElementById('finalRideBtn').addEventListener('click', (e) => {
      burstParticles(e.clientX, e.clientY, 40);
      triggerRideSequence();
    });

    document.getElementById('floatBtn').addEventListener('click', (e) => {
      burstParticles(e.clientX, e.clientY, 20);
      const msgs = [
        'Why are you still here? RIDE! 🔥',
        'Your bike misses you. 🚴',
        'Pain is just weakness leaving the body. 💪',
        'Legs heavy? Good. That means they\'re working. ⚡',
        'The only bad ride is the one that didn\'t happen. 🛣️',
        'CHARGE! 🦁',
      ];
      showToast(msgs[Math.floor(Math.random() * msgs.length)]);
    });

    document.getElementById('watchFilmBtn').addEventListener('click', (e) => {
      burstParticles(e.clientX, e.clientY, 15);
      showToast('🎬 Film coming soon. For now — go ride.', 3500);
    });

    /* ════════════════════════════════════════
       9. PARALLAX ON SCROLL — Hero Elements
       ════════════════════════════════════════ */
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          const hero = document.querySelector('section');
          if (hero && scrollY < window.innerHeight) {
            const content = hero.querySelector('.relative.z-10');
            if (content) {
              content.style.transform = `translateY(${scrollY * 0.3}px)`;
              content.style.opacity = 1 - (scrollY / (window.innerHeight * 0.8));
            }
          }
          ticking = false;
        });
        ticking = true;
      }
    });

    /* ════════════════════════════════════════
       10. CLICK SPARKS — Global
       ════════════════════════════════════════ */
    document.addEventListener('click', (e) => {
      burstParticles(e.clientX, e.clientY, 8);
    });

    /* ════════════════════════════════════════
       11. SMOOTH SCROLL — Nav Links
       ════════════════════════════════════════ */
    document.querySelectorAll('a[href^="#"]').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.querySelector(link.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    /* ════════════════════════════════════════
       12. NAVBAR HIDE/SHOW ON SCROLL
       ════════════════════════════════════════ */
    let lastScroll = 0;
    const nav = document.querySelector('nav');
    window.addEventListener('scroll', () => {
      const current = window.scrollY;
      if (current > lastScroll && current > 200) {
        nav.style.transform = 'translateY(-120%)';
        nav.style.transition = 'transform 0.4s ease';
      } else {
        nav.style.transform = 'translateY(0)';
      }
      lastScroll = current;
    });

    /* ════════════════════════════════════════
       13. TILT EFFECT — Quote Cards
       ════════════════════════════════════════ */
    document.querySelectorAll('.quote-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = ((y - centerY) / centerY) * -5;
        const rotateY = ((x - centerX) / centerX) * 5;
        card.style.transform = `translateY(-8px) perspective(800px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = 'translateY(0) perspective(800px) rotateX(0) rotateY(0)';
      });
    });

    /* ════════════════════════════════════════
       14. KEYBOARD SHORTCUT — Space to Ignite
       ════════════════════════════════════════ */
    document.addEventListener('keydown', (e) => {
      if (e.code === 'Space' && e.target === document.body) {
        e.preventDefault();
        burstParticles(canvas.width / 2, canvas.height / 2, 30);
        triggerRideSequence();
      }
    });

    /* ════════════════════════════════════════
       15. PAGE LOAD — Initial Burst
       ════════════════════════════════════════ */
    window.addEventListener('load', () => {
      setTimeout(() => {
        burstParticles(canvas.width / 2, canvas.height / 3, 25);
      }, 1500);
    });

    console.log('%c🚴 RIDE OR NOTHING', 'font-size:24px;font-weight:900;color:#f59e0b;');
    console.log('%cPress SPACE to ignite.', 'font-size:14px;color:#a8a29e;');
  </script>
</body>
</html>
